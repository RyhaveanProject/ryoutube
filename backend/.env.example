# ============================================================
# Ryhavean YouTube — Backend environment variables
# Copy this file to `.env` and fill real values.
# NEVER commit the real `.env` file to Git.
# ============================================================

# ---------- MongoDB (Atlas) ----------
# Get it from: https://cloud.mongodb.com/ → Cluster → Connect → Drivers
# Example:
#   mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="ryhavean_youtube"

# ---------- CORS ----------
# Comma-separated list of your frontend origins (Cloudflare Pages domain + custom domain).
# Example: "https://ryoutube.pages.dev,https://ryoutube.example.com"
CORS_ORIGINS="https://YOUR-FRONTEND-DOMAIN"

# ---------- JWT ----------
# Generate a strong random string (64+ chars). Example command:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET="CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING"

# ---------- Admin bootstrap ----------
# On first start the backend auto-creates / syncs this admin user.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE-ME-ON-FIRST-DEPLOY"
