# ============================================================
# Ryhavean YouTube — Backend environment variables
# Copy this file to `.env` and fill real values.
# NEVER commit the real `.env` file to Git.
# ============================================================

# ---------- MongoDB (Atlas) ----------
MONGO_URL="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="ryhavean_youtube"

# ---------- CORS ----------
CORS_ORIGINS="https://YOUR-FRONTEND-DOMAIN"

# ---------- JWT ----------
JWT_SECRET="CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING"

# ---------- Admin bootstrap ----------
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE-ME-ON-FIRST-DEPLOY"

# ============================================================
# YouTube account login (Google OAuth 2.0)
# Used for the per-user "Connect YouTube" button.
# Get them at: https://console.cloud.google.com/apis/credentials
#   1) Create OAuth client → Application type: Web application
#   2) Authorised redirect URIs:  https://YOUR-FRONTEND-DOMAIN/youtube/callback
#   3) Enable "YouTube Data API v3" in the same project
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must EXACTLY match the redirect URI registered in Google Cloud Console.
# Two valid layouts:
#   1) Frontend handles the redirect (default):
#        GOOGLE_REDIRECT_URI="https://YOUR-FRONTEND-DOMAIN/youtube/callback"
#   2) Backend handles the redirect server-side (e.g. Cloudflare Worker):
#        GOOGLE_REDIRECT_URI="https://YOUR-BACKEND-DOMAIN/youtube/callback"
#        FRONTEND_URL="https://YOUR-FRONTEND-DOMAIN"   # used to bounce back
GOOGLE_REDIRECT_URI="https://YOUR-FRONTEND-DOMAIN/youtube/callback"
# Required only when GOOGLE_REDIRECT_URI points to the backend:
FRONTEND_URL=""

# ---------- Optional: legacy global cookies (base64) ----------
# YT_COOKIES_B64=""

# ============================================================
# Stream extraction hardening (anti "Sign in to confirm you're not a bot")
# All optional. If omitted, sane defaults are used.
# ============================================================

# Comma-separated list of public Piped instances used as a last-resort
# fallback when every yt-dlp client rotation hits the bot wall on cloud IPs.
# Defaults to a curated list — override only if you self-host Piped.
# PIPED_INSTANCES="https://pipedapi.kavin.rocks,https://pipedapi.adminforge.de"

# Optional PO Token + Visitor Data forwarded to yt-dlp. Generate them with
# https://github.com/iv-org/youtube-trusted-session-generator and refresh
# every ~12h via cron. Leaving these blank is fine — yt-dlp will still
# rotate through five player_client surfaces and fall through to Piped.
# YT_PO_TOKEN=""
# YT_VISITOR_DATA=""
